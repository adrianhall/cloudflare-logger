{
  "name": "@adrianhall/cloudflare-logger",
  "version": "1.0.0",
  "description": "A small, synchronous, structured logging library for tests, browsers, and Cloudflare Workers.",
  "license": "MIT",
  "author": "Adrian Hall",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adrianhall/cloudflare-logger.git"
  },
  "sideEffects": false,
  "engines": {
    "node": ">= 24",
    "npm": ">= 11"
  },
  "files": [
    "dist",
    "skills",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "check": "run-s check:*",
    "check:dist": "npm run build && test -z \"$(git status --porcelain -- dist)\"",
    "check:format": "prettier --check .",
    "check:lint": "eslint .",
    "check:pack": "npm pack --dry-run --ignore-scripts",
    "check:types": "tsc -b",
    "fix": "run-s fix:*",
    "fix:format": "prettier --write .",
    "fix:lint": "eslint --fix .",
    "prepack": "npm run build",
    "release": "npm run build && git add dist",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "peerDependencies": {
    "react": ">= 19"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.10",
    "@cloudflare/workers-types": "^4.20250601.0",
    "@eslint/js": "^9.39.4",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-istanbul": "^4.1.7",
    "eslint": "^9.39.4",
    "globals": "^16.5.0",
    "jsdom": "^26.1.0",
    "npm-run-all2": "^8.0.4",
    "prettier": "^3.8.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.7",
    "wrangler": "^4.95.0"
  },
  "allowScripts": {
    "esbuild@0.27.7": true,
    "esbuild@0.28.1": true,
    "fsevents@2.3.3": true,
    "sharp@0.34.5": true,
    "workerd@1.20260617.1": true
  }
}
